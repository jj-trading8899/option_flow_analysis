const fmt = n => { if (!n) return "—"; if (n >= 1e6) return `$${(n/1e6).toFixed(1)}M`; if (n >= 1e3) return `$${(n/1e3).toFixed(0)}K`; return `$${n}`; };

const tc = { bullish: {bg:"#0d2818",text:"#4ade80",border:"#166534"}, bearish: {bg:"#2d0a0a",text:"#f87171",border:"#7f1d1d"}, mixed: {bg:"#1a1a0a",text:"#facc15",border:"#713f12"}, hedging: {bg:"#0a1a2d",text:"#60a5fa",border:"#1e3a5f"} };

const Bar = ({bull,bear,neut,total}) => { if(!total) return null; return (<div><div style={{display:"flex",height:6,borderRadius:3,overflow:"hidden",background:"#1a1a2e"}}><div style={{width:`${bull/total*100}%`,background:"#22c55e"}}/><div style={{width:`${bear/total*100}%`,background:"#ef4444"}}/><div style={{flex:1,background:"#525252"}}/></div><div style={{display:"flex",gap:16,marginTop:4,fontSize:10,color:"#3a3a55",fontFamily:"'JetBrains Mono',monospace"}}><span><span style={{color:"#22c55e"}}>●</span> Bull {(bull/total*100).toFixed(0)}%</span><span><span style={{color:"#ef4444"}}>●</span> Bear {(bear/total*100).toFixed(0)}%</span><span><span style={{color:"#525252"}}>●</span> Neut {(neut/total*100).toFixed(0)}%</span></div></div>); };

const Card = ({ticker, d, expanded, onToggle}) => {
  const t = tc[d.trend]||tc.mixed;
  const callPct = d.trades>0?((d.calls/d.trades)*100).toFixed(0):0;
  const spotChg = d.spotPrev?((d.spot/d.spotPrev-1)*100):null;
  const premChg = d.totalPremPrev>0?((d.totalPrem/d.totalPremPrev-1)*100):null;
  return (
    <div onClick={onToggle} style={{background:"#0f0f1a",border:`1px solid ${expanded?t.border:"#1e1e3a"}`,borderRadius:12,padding:"14px 18px",cursor:"pointer",transition:"all 0.2s"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8,flexWrap:"wrap",gap:8}}>
        <div style={{display:"flex",alignItems:"center",gap:10,flexWrap:"wrap"}}>
          <span style={{fontFamily:"'JetBrains Mono',monospace",fontSize:19,fontWeight:700,color:"#e2e8f0",letterSpacing:1}}>{ticker}</span>
          <span style={{fontSize:12,color:"#94a3b8",fontFamily:"'JetBrains Mono',monospace"}}>${d.spot?.toFixed(2)}{spotChg!=null&&<span style={{color:spotChg>=0?"#4ade80":"#f87171",marginLeft:4,fontSize:11}}>({spotChg>=0?"+":""}{spotChg.toFixed(1)}%)</span>}{d.spotPrev==null&&<span style={{color:"#facc15",marginLeft:4,fontSize:10}}>NEW</span>}</span>
          <span style={{fontSize:10,fontWeight:600,padding:"2px 10px",borderRadius:20,background:t.bg,color:t.text,border:`1px solid ${t.border}`,textTransform:"uppercase",letterSpacing:1.5}}>{d.trend}</span>
          {d.trendPrev&&d.trendPrev!==d.trend&&<span style={{fontSize:10,color:"#3a3a55"}}>was {d.trendPrev}</span>}
        </div>
        <div style={{display:"flex",alignItems:"center",gap:12,fontSize:12,color:"#64748b"}}>
          <span>{d.trades} trades</span><span>{fmt(d.totalPrem)}</span>
          {premChg!=null&&<span style={{color:premChg>=0?"#4ade80":"#f87171",fontSize:11,fontFamily:"'JetBrains Mono',monospace"}}>{premChg>=0?"+":""}{premChg.toFixed(0)}%</span>}
          <span style={{fontSize:16,transform:expanded?"rotate(180deg)":"rotate(0deg)",transition:"transform 0.2s",color:"#3a3a55"}}>▾</span>
        </div>
      </div>
      <Bar bull={d.bullPrem} bear={d.bearPrem} neut={d.neutPrem} total={d.totalPrem}/>
      {expanded&&(
        <div style={{marginTop:14,paddingTop:14,borderTop:"1px solid #1e1e3a"}}>
          <p style={{fontSize:13,lineHeight:1.75,color:"#94a3b8",margin:"0 0 14px 0"}}>{d.summary}</p>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(120px,1fr))",gap:8,marginBottom:14}}>
            {[{l:"Calls",v:`${d.calls} (${callPct}%)`,c:"#22c55e"},{l:"Puts",v:`${d.puts} (${100-callPct}%)`,c:"#ef4444"},{l:"Sweeps",v:`${d.sweeps} / ${d.trades}`,c:"#9775fa"},{l:"Sweep Prem",v:fmt(d.sweepPrem),c:"#9775fa"},...(d.avgCallStrike>0?[{l:"Avg Call $",v:`$${d.avgCallStrike.toFixed(2)}`,c:"#22c55e"}]:[]),...(d.avgPutStrike>0?[{l:"Avg Put $",v:`$${d.avgPutStrike.toFixed(2)}`,c:"#ef4444"}]:[])].map((s,i)=>(
              <div key={i} style={{background:"#070710",borderRadius:6,padding:"7px 10px"}}><div style={{fontSize:9,color:"#3a3a55",textTransform:"uppercase",letterSpacing:1,marginBottom:2}}>{s.l}</div><div style={{fontSize:13,fontWeight:600,color:s.c,fontFamily:"'JetBrains Mono',monospace"}}>{s.v}</div></div>
            ))}
          </div>
          <div style={{fontSize:10,textTransform:"uppercase",letterSpacing:1.5,color:"#3a3a55",fontWeight:600,marginBottom:6}}>Top Trades</div>
          {(d.topTrades||[]).map((tr,i)=>(
            <div key={i} style={{display:"flex",justifyContent:"space-between",padding:"5px 8px",background:i%2===0?"#070710":"transparent",borderRadius:4,fontSize:12,fontFamily:"'JetBrains Mono',monospace"}}>
              <span style={{color:tr.type==="CALL"?"#22c55e":"#ef4444",width:44,fontWeight:600}}>{tr.type}</span>
              <span style={{color:"#e2e8f0",width:55}}>${tr.strike}</span>
              <span style={{color:"#3a3a55",width:70}}>{tr.exp}</span>
              <span style={{color:"#e2e8f0",width:68,textAlign:"right"}}>{fmt(tr.prem)}</span>
              <span style={{width:65,textAlign:"right",color:tr.sent==="BULLISH"?"#22c55e":tr.sent==="BEARISH"?"#ef4444":"#facc15"}}>{tr.sent}</span>
              <span style={{width:52,textAlign:"right",color:tr.act==="SWEEP"?"#9775fa":"#3a3a55"}}>{tr.act}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  );
};

export default function App(){
  const [expanded,setExpanded]=useState(null);
  const [filter,setFilter]=useState("all");
  const [sort,setSort]=useState("premium");
  const groups={all:tickers,bullish:tickers.filter(t=>data[t].trend==="bullish"),bearish:tickers.filter(t=>data[t].trend==="bearish"),other:tickers.filter(t=>["mixed","hedging"].includes(data[t].trend)),crypto:tickers.filter(t=>["IBIT","ETHA"].includes(t))};
  let list=[...groups[filter]];
  list.sort((a,b)=>{const da=data[a],db=data[b];if(sort==="premium")return db.totalPrem-da.totalPrem;if(sort==="trades")return db.trades-da.trades;if(sort==="bullpct")return(db.bullPrem/db.totalPrem)-(da.bullPrem/da.totalPrem);if(sort==="bearpct")return(db.bearPrem/db.totalPrem)-(da.bearPrem/da.totalPrem);return a.localeCompare(b);});
  const totalPrem=tickers.reduce((s,t)=>s+data[t].totalPrem,0);
  const totalTrades=tickers.reduce((s,t)=>s+data[t].trades,0);
  const totalBull=tickers.reduce((s,t)=>s+data[t].bullPrem,0);
  const totalBear=tickers.reduce((s,t)=>s+data[t].bearPrem,0);

  return(
    <div style={{background:"#050508",minHeight:"100vh",color:"#e2e8f0",fontFamily:"'DM Sans',-apple-system,sans-serif",padding:"24px 20px"}}>
      <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
      <div style={{maxWidth:920,margin:"0 auto"}}>
        <div style={{marginBottom:22}}><h1 style={{fontSize:22,fontWeight:700,margin:0,letterSpacing:-0.5}}>Options Flow Terminal</h1><p style={{fontSize:12,color:"#3a3a55",margin:"4px 0 0",fontFamily:"'JetBrains Mono',monospace"}}>March 10, 2026 — {totalTrades.toLocaleString()} trades across {tickers.length} tickers</p></div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:10,marginBottom:20}}>
          {[{l:"Total Premium",v:fmt(totalPrem),c:"#e2e8f0"},{l:"Trades",v:totalTrades.toLocaleString(),c:"#e2e8f0"},{l:"Bull Premium",v:fmt(totalBull),c:"#22c55e"},{l:"Bear Premium",v:fmt(totalBear),c:"#ef4444"}].map((s,i)=>(
            <div key={i} style={{background:"#0f0f1a",borderRadius:8,padding:"12px 14px",border:"1px solid #1e1e3a"}}><div style={{fontSize:9,color:"#3a3a55",textTransform:"uppercase",letterSpacing:1.5,marginBottom:3}}>{s.l}</div><div style={{fontSize:18,fontWeight:700,color:s.c,fontFamily:"'JetBrains Mono',monospace"}}>{s.v}</div></div>
          ))}
        </div>
        <div style={{display:"flex",gap:8,marginBottom:16,flexWrap:"wrap",alignItems:"center"}}>
          {[{k:"all",l:"All"},{k:"bullish",l:`Bullish (${groups.bullish.length})`},{k:"bearish",l:`Bearish (${groups.bearish.length})`},{k:"other",l:`Mixed (${groups.other.length})`},{k:"crypto",l:"Crypto"}].map(f=>(<button key={f.k} onClick={()=>setFilter(f.k)} style={{padding:"5px 14px",borderRadius:20,border:"1px solid",borderColor:filter===f.k?"#4f46e5":"#1e1e3a",background:filter===f.k?"#1e1b4b":"transparent",color:filter===f.k?"#a5b4fc":"#64748b",fontSize:12,fontWeight:500,cursor:"pointer"}}>{f.l}</button>))}
          <div style={{marginLeft:"auto",display:"flex",alignItems:"center",gap:6}}><span style={{fontSize:10,color:"#3a3a55",fontFamily:"'JetBrains Mono',monospace"}}>Sort:</span><select value={sort} onChange={e=>setSort(e.target.value)} style={{background:"#0f0f1a",border:"1px solid #1e1e3a",color:"#e2e8f0",fontFamily:"'JetBrains Mono',monospace",fontSize:11,padding:"4px 8px",borderRadius:6,cursor:"pointer"}}><option value="premium">Premium</option><option value="trades">Trades</option><option value="bullpct">Bull %</option><option value="bearpct">Bear %</option><option value="alpha">Ticker</option></select></div>
        </div>
        <div style={{display:"flex",flexDirection:"column",gap:8}}>{list.map(t=>(<Card key={t} ticker={t} d={data[t]} expanded={expanded===t} onToggle={()=>setExpanded(expanded===t?null:t)}/>))}</div>
        <div style={{marginTop:24,padding:16,background:"#0a0a14",borderRadius:10,border:"1px solid #1e1e3a",fontSize:13,lineHeight:1.9,color:"#64748b"}}>
          <div style={{fontSize:10,textTransform:"uppercase",letterSpacing:1.5,color:"#3a3a55",fontWeight:600,marginBottom:8}}>Key Themes — March 10</div>
          <span style={{color:"#4ade80"}}>▲ RISK-ON BOUNCE:</span> Broad green day. NVDA +3.8% ($45.2M premium, biggest ever), HIMS +49.3% gap, BTC miners +2-5%. Most tickers flipped bullish or improved.<br/>
          <span style={{color:"#4ade80"}}>▲ NVDA CONVICTION:</span> $45.2M total, 48% bull. $1.8M call sweep ABOVE ASK at $182. Dip-buying from Friday now a full rally trade.<br/>
          <span style={{color:"#4ade80"}}>▲ XLF REVERSAL:</span> From 73% bearish (Mar 5) to 86% bullish. $2.6M put-selling at $46. Financials risk-off completely unwound.<br/>
          <span style={{color:"#4ade80"}}>▲ MINERS RECOVERING:</span> CIFR, RIOT, WULF all improved. CLSK 4th straight bullish day. IREN steady at 57% bull with $5.3M put-selling.<br/>
          <span style={{color:"#f87171"}}>▼ GOLD TURNING:</span> GLD bearish for first time — 44% bear at new high $477.52. Bearish call premium ($9.7M) signals call-selling into rally. Possible top.<br/>
          <span style={{color:"#f87171"}}>▼ SMR FLIPPED:</span> 3-day bullish streak broken, now 62% bearish. Vol-selling stopped, replaced by directional puts.<br/>
          <span style={{color:"#facc15"}}>◆ IBIT EASING:</span> Bear premium dropped 57%→46%. No longer relentlessly bearish. Call flow turned bullish for first time. ETHA cooled to mixed.<br/>
          <span style={{color:"#facc15"}}>◆ HIMS EXPLODED:</span> +49.3% gap, premium +211%. Complete reset from bearish to bullish.
        </div>
      </div>
    </div>
  );
}
